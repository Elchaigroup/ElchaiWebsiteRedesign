        .card.card--industry .card__secondary img {width: 100%;height: 100%;}
        .card.card--industry .card__head {display: flex;align-items: center;justify-content: space-between;margin-bottom: calc(1rem + 1vw);}
        .card.card--industry .card__head .icn {height: 30px;width: 30px;border: 1px solid;display: flex;justify-content: center;align-items: center;border-radius: 50%;}
        .card.card--industry .card__primary .card__body {transition: all 0.3s;height: 100%;display: flex;flex-direction: column;justify-content: space-between;}
        .card.card--blog:hover .pointer {opacity: 1;visibility: visible;transform: translate(-50%, -50%);}
        .services-list__item:not(:last-child) p {margin-bottom: calc(1rem + 0.73vw);padding-bottom: calc(1rem + 0.73vw);border-bottom: 1px solid #e0e0e0;}
        .panel.panel--success .row.row-flexible-center {row-gap: calc(2rem + 1.5vw);align-items:flex-start}
        .icn-arrow {height: 25px;width: 25px;display: flex;justify-content: center;align-items: center;border-radius: 50%;transition: all 0.3s;position: absolute;    top: 10px;right: 30px;opacity: 0;visibility: hidden; border: 1px solid #e1e1e1;}
        .solution-flow:hover .icn-arrow {opacity: 1;visibility: visible;right: 10px;}
        .icn-arrow img {height: 10px;filter: invert(1);}
        .service-head-wrapper {position: sticky;top: 100px;}
        .card.card--industry:hover:before {background: rgba(0,0,0,0.39);}
