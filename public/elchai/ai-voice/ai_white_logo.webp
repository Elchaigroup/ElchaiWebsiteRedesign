    .card.card--testimonial .client-detail {display: flex;align-items: center;width: 100%;column-gap: 18px;border-radius: 15px;    -webkit-backdrop-filter: blur(34px);    backdrop-filter: blur(34px);    border: solid 1px rgba(255, 255, 255, 0.2);background-color: rgba(0, 0, 0, 0.78);padding: 9px 12px;}
    .partners-list__item {padding: calc(1rem + 0.73vw) calc(2rem + 1vw);border-radius: 20px;background: #fff;border: 1px solid #eaeaea;}
    .partner-list__primary {animation-direction: normal;animation-delay: 0s;animation-play-state: running;animation: scroll 93.6s linear 0s infinite;}
    .partner-list__primary, .partner-list__secondary {flex: 0 0 auto;display: flex;min-width: auto;flex-direction: row;align-items: center;column-gap: 30px;}
    @keyframes scroll {
        0% {
            transform: translateX(0%);
        }
        100% {
            transform: translateX(-100%);
        }
    }
    .partner-list__secondary{animation-direction: normal;animation-delay: 0s;animation-play-state: running;animation: scroll-reverce 93.6s linear 0s infinite;}
    @keyframes scroll-reverce {
        0% {
            transform: translateX(-100%);
        }
        100% {
            transform: translateX(0%);
        }
    }
