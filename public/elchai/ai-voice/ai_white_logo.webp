<style>
    /* ----------- [ ROOT ] ========= */
    :root{
        --color-primary: #52b8ff;
        --color-secondary: #08323d;
        --color-white: #fff;
        --color-black: #000;
        --color-dark: #282828;
        --text-primary: #52b8ff;
    }
    /* ----------- [ TYPOGRAPHI ] ========= */
    h1 {font-size: calc(1.375rem + 1.5vw);}
    h2 {font-size: calc(1.325rem + .9vw);}
    h3 {font-size: calc(1.3rem + .6vw);}
    h4 {font-size: calc(1.275rem + .3vw);}
    h5 {font-size: 1.25rem;}
    h6 {font-size: 1rem;}
    @media(min-width:1200px){
        h1{font-size: 2.5rem}   /*----40-----*/
        h2{font-size: 2rem}     /*----32-----*/
        h3{font-size: 1.75rem}  /*----28-----*/
        h4{font-size: 1.5rem}   /*----24-----*/
        h5{font-size: 1.25rem}  /*----20-----*/
        h6{font-size: 1rem}     /*----16-----*/
    }
    @media(min-width:1600px){
        h1{font-size: 4rem} /*----60-----*/
        h2{font-size: 2.875rem}/*----46-----*/
        h3{font-size: 2.25rem} /*----36-----*/
        h4{font-size: 1.75rem} /*----28-----*/
        h5{font-size: 1.5rem}  /*----24-----*/
        h6{font-size: 1.25rem} /*----20-----*/
    }   
    /* ----------- [ BUTTON ] ========= */   
    @keyframes button{0%{transform:translateY(3.125rem);opacity:0}39.1%{transform:translateY(2.625rem)}52.2%{opacity:0}87%{opacity:1}to{transform:translateY(0);opacity:1}}

    .btn-common::before {
        -webkit-animation: shine 1.5s ease-in-out infinite;
        animation: shine 1.5s ease-in-out infinite;
    }
    @-webkit-keyframes shine {
        0% {
            left: -100%;
        }
        100% {
            left: 100%;
        }
    }

    @keyframes shine {
        0% {
            left: -100%;
        }
        100% {
            left: 100%;
        }
    }
    
   
    /* ----------- [ COMMON CSS ] ========= */
    body{color: var(--color-black);}
    html {font-size: 1rem;}
    h1, h2, h3, h4, h5, h6{font-weight:600}
    .partnership-independent-cta {display: none;}
    body .fade.show {opacity: 1;}
    h1, h2, h3, h4, h5, p{margin-top:0}
    ol, ul{margin:0;padding:0;list-style:none}
    body .modal-backdrop.show {opacity: 0.5 !important;}
    header .btn-register-header {background: var(--color-primary);border: none;font-weight: 600;color: #000;border-radius:3px}
    header .btn-register-header:before{border: 3px solid #000;animation: pulso-white 2s infinite;}
    #mainNav .container {width: 100%;padding: 0 7% 0;}  
    .header-fixed .fixed-download-bottom, .header-fixed .commonbs5form.common-git-btn-footer {color: #000 !important;font-weight: 600;background:var(--color-primary);z-index:999}
    .fixed-logo {display: block;}
    .normal-logo {display: none;}
    .top_header_container ul {margin-bottom: 10px;}
    footer.rewamp-footer {background: #fff;}
    .footer_carousel .carousel-indicators{justify-content:flex-start}
    .line {border-color: #979797;}
    .color-black{color:#000 !important}
    .color-white{color:#fff !important}
    .color-primary{color:var(--text-primary) !important}
    .color-secondary{color:var(--color-secondary)}
    .bg-dark{background-color: var(--color-black) !important;color:#fff}
    .bg-primary{background:var(--color-primary) !important}
    .bg-secondary{background:var(--color-secondary)}
    br {display: none;}
    b, strong {font-weight: 600;}
    .mb-sm-0 {margin-bottom: 0 !important;}
    .p-0{padding:0 !important}
    .pb-0{padding-bottom:0 !important}
    .pt-0 {padding-top: 0 !important;}
    .mb-0{margin-bottom:0 !important}
    .mr-2 {margin-right: 0.5rem;}
    body .fade.in {opacity: 1;}
    body .modal-backdrop.in {opacity: 0.5 !important;}
    .card .card-body p {margin: 0;}
    .section__head h2 { margin-top:0;margin-bottom: 0.625rem;color:inherit;}
    .section__head .newStyleBtnss {margin-top: calc(1rem + 1vw);}
    .newStyleBtnss {background: var(--color-primary);color: #fff;}
    .section {padding: calc(3rem + 2.5vw) 0;}
    .section__head {margin-bottom: calc(2rem + 2vw);}
    .carousel-caseStudy .horizontalDots {width: 100%;margin: 0px;position: relative;left: 0px;display: flex;justify-content: start;align-items: start;flex-direction: column;text-align:left}
 .carousel-caseStudy .horizontalDots li[data-bs-target] {text-indent:0; height:auto!important; width:100%!important; margin:0; padding:15px 0; border-radius:10px; font-size:18px; font-stretch:normal; font-style:normal; letter-spacing:0; position:relative; background:#1a1a1a; opacity:1; padding:0; transition:.3s; line-height:1; font-size:calc(1rem + .35vw); display:block; color:#fff!important; font-weight:600; border: 1px solid #1a1a1a;}
     .carousel-caseStudy .carousel-indicators.horizontalDots {row-gap: 15px;height: 100%;}
    .carousel-caseStudy .carousel-indicators.horizontalDots li[data-bs-target].active .indicater-item h4, .carousel-caseStudy .carousel-indicators.horizontalDots li.active .indicater-item p {color: #fff;}
    .carousel-caseStudy .carousel-indicators.horizontalDots li[data-bs-target].active .indicater-item {background: #1a1a1a;}
     .carousel-caseStudy .carousel-indicators.horizontalDots li[data-bs-target].active{border-color: #8d92ff;}
    
    .panel {margin-bottom: 20px;background-color: #fff;border: 1px solid transparent;border-radius: 4px;-webkit-box-shadow: 0 1px 1px rgba(0,0,0,.05);box-shadow: 0 1px 1px rgba(0,0,0,.05);}
    body.ROW {display: unset;margin: unset;--bs-gutter-x: unset;}
    body.ROW .page_wrapper {margin: unset;padding: unset;width: unset;max-width: unset;}

.partners-slider {
    opacity: 0;
    visibility: hidden;
    height: 0;
    overflow: hidden;
}

.partners-slider.slick-initialized{
    opacity: 1;
    visibility: visible;
    height: auto;
    overflow: visible;
    transition: opacity 0.4s ease;
}
    /* ----------- [ ACCORDIAN ] ========= */
    @media(max-width:991px){
        .accordion-head{display:flex;align-items:center;padding:0;position:relative;justify-content:space-between}
        .accordion-head.is-active::before{transform: rotate(85deg) translateY(6%) translatex(-49%);}
        .accordion-head .pointer-arrow svg {height: 32px;width: 32px;}
        .accordion-head.is-active .pointer-arrow {transform: rotate(90deg);}
        .accordion-head.is-active .pointer-arrow svg g {fill: #8eb500;}
        .accordion-head .pointer-arrow {display: flex;transition: all 0.3s;}
        .accordion-head.is-active::before {transform: rotate(90deg) translateY(6%) translatex(-49%);}
        .accordion-head .icn{width: 30px;margin-right: 1rem;height: 30px;display: flex;justify-content: center;}
        .accordion-body p {margin-bottom: 0;font-size: 16px;}
        .accordion-head h5,.common-section-all.section--platform [class*=col-]:not(:last-child){margin-bottom:0}
        .accordion-body .accordion-img{height:auto;overflow:hidden;width:100%;margin-right:2rem;margin-bottom:2rem}
        .accordion-content .check-list img{filter:brightness(.5)}
        .accordion-body .btn {margin-top: 20px;}
        .accordion-intigrations .accordion-body img {margin-bottom: 15px;height: 146px;width: 100%;object-fit: cover;object-position: center;border-radius: 12px;}
        .accordion-action {height: 32px;min-width: 32px;display: flex;justify-content: center;align-items: center;background: var(--color-primary);border-radius: 50%;transition:all 0.3s}
        .accordion-action img {height: 15px;transform: rotate(90deg);}
        .accordion-head.is-active .accordion-action img {transform: rotate(-90deg);}
        .accordion-wrapper.accordion-Customer .accordion--features:not(:last-child) {margin-bottom: 10px;padding-bottom: 10px;border-bottom: 1px solid #e6e6e6;}
        .accordion.accordion--features:not(:last-child) {margin-bottom: 20px;padding-bottom: 20px;border-bottom: 1px solid #dfdfdf;}
        .accordion-body {margin-top: 15px;}

    }
    .section__head p {color: #cacaca;}
    
    .avatar-meta {display: flex;flex-direction: column;text-align: center;align-items: center;row-gap: calc(0.5rem + 0.63vw);cursor: pointer;}
    .avatar-meta .avatar {height: calc(2rem + 1.2vw);width: calc(2rem + 1.2vw);display: flex;justify-content: center;align-items: center;}
    .avatar-position:before {content: "";position: absolute;width: 13px;height: 17px;left: -9px;top: -19px;background-image:url(https://www.elchaigroup.com/wp-content/themes/prisma-child/media/2025/images/nav-arrow.webp)}
    .avatar-position {background: #f1f1f1;padding: 0 calc(1rem + 0.3vw);text-transform: capitalize;color: #393939;line-height: 2;font-size: calc(0.5rem + 0.55vw);position: relative;transition: all 0.3s;}
    .text-to-change {transition: color 0.6s ease;}
    .banner-primary [class*="col-"]:nth-child(even) .avatar-meta {flex-direction: column-reverse;}
    .avatar-meta:hover .avatar-position {background: var(--color-primary);color: #000;font-weight: 600;}
    .avatar-meta:hover .bounce {animation: bounce 2s ease infinite;}
    @keyframes bounce {
        0%, 20%, 50%, 80%, 100% {transform: translateY(0);}
        40% {transform: translateY(-15px);}
        60% {transform: translateY(-15px);}
    }
