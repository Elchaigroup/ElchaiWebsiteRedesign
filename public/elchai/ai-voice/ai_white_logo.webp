<script>
	$(document).ready(function() {
		$('.video_card').on('mouseenter', function() {
			$(this).find('.video_poster').hide();
			$(this).find('.unmute').show();
			$(this).find('.mute').hide();
			var video = $(this).find('video')[0];
			video.muted = true;
			video.play();
		});

		$('.video_card').on('mouseleave', function() {
			var video = $(this).find('video')[0];
			video.pause();
			video.muted = true
			$(this).find('.video_poster').show();
			$(this).find('.unmute,.mute').hide();
		});

		$('.unmute').on('click', function() {
			$(this).parents('.video_card').find('.video_poster').hide();
			var video = $(this).parents('.video_card').find('video')[0];
			video.play();
			video.muted = false;
			$(this).hide();
			$(this).siblings('.mute').show();
		});
		$('.mute').on('click', function() {
			var video = $(this).parents('.video_card').find('video')[0];
			video.muted = true;
			$(this).hide();
			$(this).siblings('.unmute').show();
		});
	});
</script>

