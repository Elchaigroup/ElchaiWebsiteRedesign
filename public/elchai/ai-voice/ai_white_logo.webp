	#primary_form input.form-control-input {padding:12px 14px; border-radius:10px; border:solid 1px rgba(255, 255, 255, 0.2); background-color:rgba(255, 255, 255, 0.05); width:100%; margin-bottom:15px; color:#fff;}
	#primary_form textarea.form-control-input {padding:12px 14px; border-radius:10px; border:solid 1px rgba(255, 255, 255, 0.2); background-color:rgba(255, 255, 255, 0.05); width:100%; margin-bottom:10px; color:#fff;}
	#primary_form input:focus-visible {outline:-webkit-focus-ring-color auto 0px;}
	#primary_form input:focus-visible {outline:focus-ring-color auto 0px;}
