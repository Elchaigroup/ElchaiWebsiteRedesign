   $(".js-group-body").hide();
   $(".js-group-head").click(function() {
      if ($(this).parents('.js-group').hasClass('is-active')) {
         $(this).siblings('.js-group-body').slideUp();
         $('.js-group').removeClass('is-active');
      } else {
         $('.js-group').removeClass('is-active');
         $(this).parents('.js-group').addClass('is-active');
         $('.js-group-body').slideUp();
         $(this).siblings('.js-group-body').slideDown();
      }
   });
</script>
<script>
    jQuery(function($){
        var $slider = $('.partners-slider');
        if (!$slider.length) return;

        // --- 1) Clone slides once for seamless loop ---
        if (!$slider.data('marquee-cloned')) {
            var $clone = $slider.children().clone(true);
            $slider.append($clone);
            $slider.data('marquee-cloned', true);
        }
        // --- 2) Init slick (no autoplay) ---
        $slider.slick({
            slidesToShow: 6,
            slidesToScroll: 1,
            infinite: true,
            variableWidth: true,
            arrows: false,
            dots: false,
            autoplay: false,        // disabled: we'll animate manually
            swipe: true,
            draggable: true,
            pauseOnHover: false,
            pauseOnFocus: false,
            accessibility: false,
            waitForAnimate: false,
            useTransform: true
        });

        // Wait until slick has laid out slides
        $slider.on('init reInit setPosition', function(){
            startMarquee();
        });

        // In case slick already initialized before binding (rare), call startMarquee:
        startMarqueeIfReady();

        // ---------------- marquee animation code ----------------
        var rafId = null;
        var lastTime = performance.now();
        var offset = 0;
        var speed = 60; // px per second — tweak this (higher = faster)
        var running = true;
        var $track, trackWidth, loopWidth;

        function startMarqueeIfReady(){
            // slick may already be ready
            if ($slider.find('.slick-track').length) startMarquee();
        }

        function computeSizes(){
            $track = $slider.find('.slick-track');
            // remove transition to avoid conflicts
            $track.css('transition', 'none');

            // compute total width of slick slides (including clones appended)
            var w = 0;
            $track.find('.slick-slide').each(function(){
                w += $(this).outerWidth(true);
            });
            trackWidth = w;
            // loopWidth is half of the track (we duplicated once)
            loopWidth = trackWidth / 2 || trackWidth;
            // clamp offset to loopWidth
            offset = offset % loopWidth;
        }

        function startMarquee(){
            cancelAnimationFrame(rafId);
            computeSizes();
            lastTime = performance.now();
            running = true;
            rafId = requestAnimationFrame(frame);
        }

        function frame(now){
            var dt = (now - lastTime) / 1000;
            lastTime = now;

            if (running) {
                offset += speed * dt;
                if (offset >= loopWidth) offset -= loopWidth;
                // apply transform (override Slick's transform while animating)
                $track[0].style.transform = 'translate3d(' + (-offset) + 'px, 0, 0)';
            }

            rafId = requestAnimationFrame(frame);
        }

        // Utility: read current translateX from computed transform
        function getCurrentTranslateX(){
            var el = $track && $track[0];
            if (!el) return 0;
            var st = window.getComputedStyle(el);
            var tr = st.transform || st.webkitTransform || 'none';
            if (tr === 'none') return 0;
            var match3d = tr.match(/^matrix3d\((.+)\)$/);
            if (match3d) {
                var vals = match3d[1].split(', ');
                return parseFloat(vals[12]) || 0;
            }
            var match2d = tr.match(/^matrix\((.+)\)$/);
            if (match2d) {
                var vals = match2d[1].split(', ');
                return parseFloat(vals[4]) || 0;
            }
            return 0;
        }

        // Pause/resume helpers (keeps continuity)
        function pauseMarquee(){
            running = false;
        }
        function resumeMarquee(){
            // compute offset from current transform so resume is seamless
            var tx = getCurrentTranslateX(); // usually negative when moving left
            offset = Math.abs(tx) % loopWidth;
            lastTime = performance.now();
            running = true;
        }

        // Hover pause (desktop)
        $slider.on('mouseenter', function(){ pauseMarquee(); });
        $slider.on('mouseleave', function(){ resumeMarquee(); });

        // Pause when user starts dragging/touching; resume on end
        $slider.on('mousedown touchstart', function(){ pauseMarquee(); });
        $(document).on('mouseup touchend touchcancel', function(){ 
            // small timeout helps if user clicks quickly
            setTimeout(function(){ resumeMarquee(); }, 50); 
        });

        // Recompute sizes on window resize and when slick re-positions
        $(window).on('resize', function(){
            // small debounce
            clearTimeout($slider.data('resize-timer'));
            $slider.data('resize-timer', setTimeout(function(){
                computeSizes();
            }, 120));
        });

        $slider.on('setPosition', function(){
            computeSizes();
        });

        // Stop RAF when leaving page (cleanup)
        $(window).on('blur unload beforeunload', function(){
            cancelAnimationFrame(rafId);
        });

    });
</script>