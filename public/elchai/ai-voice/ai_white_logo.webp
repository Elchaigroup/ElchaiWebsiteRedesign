    .panel.panel--solutions {padding: calc(2rem + 1.2vw);position: relative;border-radius: 20px; border: solid 1px #444; background-color: #191919; color: #fff;}
    .panel-cover {position: absolute;left: 0;right: 0;top: 0;bottom: 0;z-index: 1;}
