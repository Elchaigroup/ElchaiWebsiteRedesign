<div class="modal fade" id="bs5popup_main" tabindex="-1" role="dialog" aria-labelledby="myModalLabel">
	<div class="modal-dialog" role="document">
		<div class="modal-content " id="formly-covered">
			<button type="button" class="close pop-close"data-bs-toggle="modal" data-bs-target="#bs5popup_main"><span aria-hidden="true">&times;</span> </button>             
			<div class="form-blockchain" id="this_one">
				<div id="primary_form" class="blockchain_form  pri_popup" name="blockchainform">
					<div class="first-field" style="display: block;">
						<div class="row row-flexible-stretch">
							<div class="col-sm-12 col-lg-6 form_leftarea">  
								<div class="edge_form">
									<div class="edge_1">
										<p class="form_tag">Schedule Your Consultation Today! </p>
										<h3>Build Your Next Project With Industry Experts</h3>  
										<p class="by_adds">Leverage cutting-edge technology and proven expertise to transform your business.</p>
									</div>
									<div class="edge_2">
										<p><i class="fa-regular fa-envelope"></i> <a href="mailto:info@elchaigroup.com">info@elchaigroup.com</a></p>
									</div>
								</div>
							</div>
							<div class="col-md-12 col-lg-6 right_form">
								<div class="panel panel--form">
									<form class="popup-form">
										<div class="panel__head">
											<div class="form_title"><h4 class="form_title"><b>Fill out the form below,</b> and our team will reach out to discuss your project.</h4></div>
										</div>
										<div class="panel__body">
											<div class="form_row">                                          
												<div class="form_field form-floating">
													<input type="text" class="form-control-input  incomplete-values" placeholder="Name" id="fname" name="firstname">
													<span class="error-msg error-msg1"></span>
												</div>
												<div class="form_field form-floating">
													<input type="text" class="form-control-input incomplete-values" placeholder="Email" id="email" name="email">
													<span class="error-msg error-msg2"></span>
												</div>
												<div class="form_field form-floating" style="z-index: 9;">
													<input type="text" class="form-control-input incomplete-values" id="autoleadphone" placeholder="Phone" name="phone" onkeypress="return isNumberKey(event)">
													<span class="error-msg error-msg3"></span>
												</div>
												<div class="form_field form-floating">
													<input type="text" class="form-control-input bcflooking  incomplete-values" placeholder="I Am looking For" id="flooking" name="flooking">
													<span class="error-msg error-msg4"></span>
												</div>
												<div class="form_field form-floating">
													<textarea class="bcleadmessage incomplete-values form-control-input" name="message" rows="4" placeholder="Describe Your Project / Idea In Brief"></textarea>
												</div>
											</div>
										</div>
										<div class="panel__foot">
											<div class="panel__action btn-common btn-common-primary">
												<input class="bulid_app_outer" id="get_value" type="submit" value="Submit">
											</div>                             

										</div>
									</form> 
									<p class="confidential_tag">All information you provide will remain confidential.</p>
								</div>
							</div>
						</div>
					</div>              
				</div>
			</div>
		</div>
	</div>
</div>
<script>
	// Existing click event handler
	jQuery('.commonbs5form').on('click', function (e) {
		e.preventDefault(); // Default behavior ko prevent karna

		// Blockchain modal ko show karna
		jQuery('#bs5popup_main').modal('show');

	});
</script>

<script>
	function isNumberKey(evt) {
		var charCode = evt.which ? evt.which : evt.keyCode;
		if (charCode > 31 && (charCode < 48 || charCode > 57)) {
			return false;
		}
		return true;
	}	

</script>

<script>
	jQuery(document).ready(function ($) {
		/* ================= REAL-TIME ERROR CLEAR ================= */
		$(document).on('input change', '.popup-form input, .popup-form textarea', function () {
			$(this).siblings('.error-msg').text('');
		});
		$(document).on('submit', '.popup-form', function (e) {
			e.preventDefault();
			let form = $(this);
			let isValid = true;
			console.clear();
			console.log('Form submit triggered');

			// clear old errors
			form.find('.error-msg').text('');

			// scoped values
			let fname   = form.find('#fname').val().trim();
			let email   = form.find('#email').val().trim();
			let phone   = form.find('#autoleadphone').val().trim();
			let looking = form.find('#flooking').val().trim();
			let message = form.find('[name="message"]').val().trim();

			console.table({ fname, email, phone, looking, message });

			/* ================= NAME ================= */
			if (!fname) {
				form.find('#fname')
					.siblings('.error-msg')
					.text('Please enter your name');
				isValid = false;
			}

			/* ================= EMAIL ================= */
			let emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

			if (!email) {
				form.find('#email')
					.siblings('.error-msg')
					.text('Please enter your email');
				isValid = false;

			} else if (!emailPattern.test(email)) {
				form.find('#email')
					.siblings('.error-msg')
					.text('Enter valid email');
				isValid = false;
			}

			/* ================= PHONE ================= */
			if (!phone) {
				form.find('#autoleadphone')
					.siblings('.error-msg')
					.text('Please enter phone number');
				isValid = false;

			} else if (!/^[0-9]{10}$/.test(phone)) {
				form.find('#autoleadphone')
					.siblings('.error-msg')
					.text('Enter valid 10 digit phone number');
				isValid = false;
			}

			/* ================= STOP IF INVALID ================= */
			if (!isValid) {
				console.error('❌ Validation failed');
				return false;
			}

			console.log('✅ Validation passed');

			/* ================= AJAX ================= */
			$.ajax({
				url: "https://www.elchaigroup.com/wp-content/themes/prisma-child/send-mail.php",
				type: "POST",
				data: { fname, email, phone, looking, message },

				beforeSend() {
					console.log('📤 Sending AJAX...');
				},

				success(response) {
					console.log('✅ Server response:', response);
					//alert('Thank you! We will contact you soon.');
					form[0].reset();
					window.location.href = "/thankyou"; 
				},

				error(xhr, status, error) {
					console.error('❌ AJAX error:', error);
				}
			});

		});

	});
</script>
<script>
	jQuery(document).ready(function ($) {

		// phone: numeric only + max 12 digits
		$('#InputPhone').on('input', function () {
			this.value = this.value.replace(/[^0-9]/g, '').slice(0, 10);
		});

		$(document).on('submit', '#footersideform', function (e) {

			e.preventDefault();

			let form = $(this);
			let isValid = true;

			console.clear();
			console.log('Footer form submit triggered');

			// clear old error
			form.find('.error-msg').remove();

			// get values
			let firstName = form.find('#InputFirstName').val().trim();
			let lastName  = form.find('#InputLasttName').val().trim();
			let email     = form.find('#InputEmail').val().trim();
			let phone     = form.find('#InputPhone').val().trim();
			let message   = form.find('#InputMessage').val().trim();

			console.table({
				firstName,
				lastName,
				email,
				phone,
				message
			});

			/* ================= PHONE VALIDATION ================= */
			if (!phone) {
				form.find('#InputPhone')
					.after('<span class="error-msg">Please enter phone number</span>');
				isValid = false;

			} else if (!/^[0-9]{10}$/.test(phone)) {
				form.find('#InputPhone')
					.after('<span class="error-msg">Enter valid 10 digit phone number</span>');
				isValid = false;
			}

			/* ================= STOP IF INVALID ================= */
			if (!isValid) {
				console.error('❌ Validation failed');
				return false;
			}

			// show loader
			form.find('.processing-wheel').show();

			/* ================= AJAX ================= */
			$.ajax({
				url: "https://www.elchaigroup.com/wp-content/themes/prisma-child/send-mail.php",
				type: "POST",
				data: {
					fname:firstName,
					lastName,
					email,
					phone,
					message,
					formType: 'footer'
				},

				beforeSend() {
					console.log('📤 Sending footer form AJAX...');
				},

				success(response) {
					console.log('✅ Server response:', response);
					//alert('Thank you! We will contact you soon.');
					form[0].reset();					
					window.location.href = "/thankyou"; 
				},

				error(xhr, status, error) {
					console.error('❌ AJAX error:', error);
				},

				complete() {
					form.find('.processing-wheel').hide();
				}
			});

		});

	});
</script>

<script>
	jQuery(document).ready(function ($) {

		const phoneInput = document.querySelector('.whatsAppPhone');

		const iti = window.intlTelInput(phoneInput, {
			initialCountry: "auto",
			separateDialCode: true,
			nationalMode: false,
			autoPlaceholder: "polite",
			geoIpLookup: function (callback) {
				fetch("https://ipapi.co/json/")
					.then(res => res.json())
					.then(data => {
					callback(data.country_code.toLowerCase());
				})
					.catch(() => {
					callback("in"); // fallback India
				});
			},
			utilsScript:
			"https://cdn.jsdelivr.net/npm/intl-tel-input@18.3.1/build/js/utils.js"
		});

		/* ================= FORM SUBMIT ================= */
		$(document).on('submit', '#subscribeform-whatsApp', function (e) {
			e.preventDefault();

			let form = $(this);
			form.find('.error-msg').remove();

			if (!iti.isValidNumber()) {
				$('.whatsAppPhone')
					.after('<span class="error-msg">Enter valid phone number</span>');
				return false;
			}

			let phone = iti.getNumber(); // auto with country code
			let message = 'Whatsapp Newsletter';

			$.ajax({
				url: "https://www.elchaigroup.com/wp-content/themes/prisma-child/send-mail.php",
				type: "POST",
				data: {
					phone: phone,
					message: message,
					formType: 'whatsapp-footer'
				},
				success() {
					alert('Thank you! We will contact you on WhatsApp.');
					form[0].reset();
					iti.setCountry("auto");
					window.location.href = "/thankyou"; 
				}
			});
		});

	});
</script>
<script>
	jQuery(document).ready(function ($) {

		let customRedirectUrl = null;

		/* ================= CASE STUDY BUTTON CLICK ================= */
		$(document).on('click', '.commonbs5form', function (e) {
			e.preventDefault();

			customRedirectUrl = $(this).data('redirect') || null;

			/* 🔓 OPEN FORM POPUP ONLY */
			$('.popup-form').closest('.modal, .popup, .form-popup').addClass('active');

			/* OPTIONAL: focus first input */
			setTimeout(() => {
				$('.popup-form #fname').focus();
			}, 300);
		});

		/* ================= HANDLE REDIRECT AFTER AJAX ================= */
		$(document).ajaxSuccess(function () {
			if (customRedirectUrl) {
				window.location.href = customRedirectUrl;
				customRedirectUrl = null;
			}
		});

	});
</script>



<script>
	/*! jquery.cookie v1.4.1 | MIT */
	!function(a){"function"==typeof define&&define.amd?define(["jquery"],a):"object"==typeof exports?a(require("jquery")):a(jQuery)}(function(a){function b(a){return h.raw?a:encodeURIComponent(a)}function c(a){return h.raw?a:decodeURIComponent(a)}function d(a){return b(h.json?JSON.stringify(a):String(a))}function e(a){0===a.indexOf('"')&&(a=a.slice(1,-1).replace(/\\"/g,'"').replace(/\\\\/g,"\\"));try{return a=decodeURIComponent(a.replace(g," ")),h.json?JSON.parse(a):a}catch(b){}}function f(b,c){var d=h.raw?b:e(b);return a.isFunction(c)?c(d):d}var g=/\+/g,h=a.cookie=function(e,g,i){if(void 0!==g&&!a.isFunction(g)){if(i=a.extend({},h.defaults,i),"number"==typeof i.expires){var j=i.expires,k=i.expires=new Date;k.setTime(+k+864e5*j)}return document.cookie=[b(e),"=",d(g),i.expires?"; expires="+i.expires.toUTCString():"",i.path?"; path="+i.path:"",i.domain?"; domain="+i.domain:"",i.secure?"; secure":""].join("")}for(var l=e?void 0:{},m=document.cookie?document.cookie.split("; "):[],n=0,o=m.length;o>n;n++){var p=m[n].split("="),q=c(p.shift()),r=p.join("=");if(e&&e===q){l=f(r,g);break}e||void 0===(r=f(r))||(l[q]=r)}return l};h.defaults={},a.removeCookie=function(b,c){return void 0===a.cookie(b)?!1:(a.cookie(b,"",a.extend({},c,{expires:-1})),!a.cookie(b))}});
</script>
<script>
	$( document ).ready(function() {
		if (typeof getCookie('referrer') == 'undefined') {
			var gettheReferrer = document.referrer;
			setCookie('referrer',gettheReferrer); 
		}
		else {
			if( getCookie('referrer') != '') {
				// Not to update cookie
			}
			else {
				var gettheReferrer = document.referrer;
				if(gettheReferrer == '') {
					setCookie('referrer','direct');
				}
				else {
					setCookie('referrer',gettheReferrer);
				}
			}
		}
	});
	function setCookie(cname, cvalue, exdays) {
		var d = new Date();
		d.setTime(d.getTime() + (exdays *  24 *  60 *  60 *  1000));
		var expires = "expires="+d.toUTCString();
		//document.cookie = cname + "=" + cvalue + ";" + expires + ";" + path + "/";
		document.cookie = cname + "=" + cvalue + ";" + expires + ";path=/";
	}
	function getCookie(cname) {
		var name = cname + "=";
		var decodedCookie = decodeURIComponent(document.cookie);
		var ca = decodedCookie.split(';');
		for(var i = 0; i < ca.length; i++) {
			var c = ca[i];
			while (c.charAt(0) == ' ') {
				c = c.substring(1);
			}
			if (c.indexOf(name) == 0) {
				return c.substring(name.length, c.length);
			}
		}
		return "";
	}
</script>
