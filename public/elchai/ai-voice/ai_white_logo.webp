	.edge_form .by_adds {font-size:18px;}
	.form_tag {padding:10px 20px; border-radius:10px; -webkit-backdrop-filter:blur(40px); backdrop-filter:blur(40px); border-image-source:linear-gradient(to right, #52b8ff, #b07cff); border-image-slice:1; background-image:linear-gradient(to bottom, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.1)), linear-gradient(to right, #52b8ff4f, #b07cff2e); display:inline-flex; font-size:16px; margin-bottom:calc(1rem + 0.5vw); border:1px solid #869fff; font-weight:600;}
	#bs5popup_main button.close {position:absolute; z-index:999; right:-14px; top:-14px; background:var(--color-primary); border:0; font-size:24px; opacity:1; line-height:24px; padding:4px 6px; width:30px; height:30px; border-radius:5px;}
	#bs5popup_main .modal-dialog {width:100%; max-width:1036px; position:absolute; left:50%; top:50%; transform:translate(-50%,-50%);}
