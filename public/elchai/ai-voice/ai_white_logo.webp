    .solution-flow {text-align: center;display: flex;flex-direction: column;align-items: center;row-gap: calc(1rem + 0.73vw);padding: calc(1rem + 1.25vw) 10px;transition:all 0.3s;position:relative;border: solid 1.1px rgba(255, 255, 255, 0.2); background-color: #292929;}
    .solution-flow span {font-weight: 500;font-size: 16px;}
    .solution-flow:hover {border: solid 1.1px rgba(255, 255, 255, 0.2); background-color: #404040;;cursor: pointer;}
