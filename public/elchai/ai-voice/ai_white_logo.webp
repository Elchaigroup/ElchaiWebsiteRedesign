	.edge_2 p {padding:10px 20px; border-radius:10px; -webkit-backdrop-filter:blur(20px); backdrop-filter:blur(20px); border:solid 1px rgba(255, 255, 255, 0.2); background-color:rgba(255, 255, 255, 0.1); display:inline-flex; font-size:18px; display:inline-flex; align-items:center; column-gap:10px;}
	.right_form .panel__action {width:100%; text-align:center; margin:1rem 0;}
	.right_form .panel__action span {z-index:1; margin:0 auto;}
	.right_form .panel__action input[type="submit"] {background:transparent; border:0; margin:0 auto; font-weight:600; color:#fff; width:100%;}
	.confidential_tag {opacity:0.6; font-size:16px;}
	.form_title {font-size:18px; margin-bottom:1rem;}
	.panel.panel--form {border-radius:20px; border:solid 1px rgba(255, 255, 255, 0.1); background-color:#191919; padding:calc(1rem + 1vw) calc(1rem + 0.5vw); margin-bottom:0;}
