<script>
	//========= [ ACCORDION ========= -->
	$('.trigger-js').click(function () {
		let isParMegaBody = $(this).parents('.maga-body-js').length;
		console.log($(this).hasClass("is-active"), 'is-active');
		if ($(this).hasClass("is-active")) {
			if (isParMegaBody == 0) {
				$(this).removeClass("is-active").siblings('.target-js').slideUp();
				$('body').removeClass('toggle-active');
				$('.trigger-js').removeClass('is-active');
				$('.target-js').slideUp();
			}
			return;
		}
		if (isParMegaBody) {
			$('.trigger-js').removeClass('is-active');
			$('.target-js').slideUp();
			$(this).addClass("is-active").siblings('.target-js').show();
			if ($(document).width() <= 767) {
				$('.trigger-js').removeClass('is-active');
				$('.target-js').slideUp();
				$(this).addClass("is-active").siblings('.target-js').slideDown();
			}
			let megaBodyItem = magaFilter.find('.trigger-js:first');
			megaBodyItem.addClass('is-active').siblings('.target-js').show();
		} else {
			$('.trigger-js').removeClass('is-active');
			$('.target-js').slideUp();
			$(this).addClass("is-active").siblings('.target-js').slideDown();
		}
		$('body').addClass('toggle-active');
	});



</script>


