<script>
	$(document).ready(function() {
		// Function to check which service is currently in view
		function updateActiveService() {
			var scrollPosition = $(window).scrollTop();

			// Loop through each section and check if it's in view
			$('.panel--solutions').each(function() {
				var sectionOffset = $(this).offset().top - 150; // Adjust this offset as needed
				var sectionHeight = $(this).outerHeight();
				var sectionId = $(this).attr('id');

				if (scrollPosition >= sectionOffset && scrollPosition < sectionOffset + sectionHeight) {
					$('.solution-list__item').removeClass('active'); // Remove active from all
					$('a[href="#' + sectionId + '"]').addClass('active'); // Add active to the current
				}
			});
		}
		// Trigger the function on scroll
		$(window).on('scroll', function() {
			updateActiveService();
		});

		// When clicking on a service in the list, scroll to the corresponding section
		$('.solution-list__item').on('click', function(e) {
			e.preventDefault(); // Prevent default anchor behavior

			// Remove active from all and add to the clicked one
			$('.solution-list__item').removeClass('active');
			$(this).addClass('active');

			// Scroll to the target section
			var target = $(this).attr('href');
			$('html, body').animate({
				scrollTop: $(target).offset().top - 120 // Adjust offset for sticky header
			}, 500); // 500ms scroll duration
		});

		// Initially, update the active service based on the scroll position
		updateActiveService();
	});
</script>
<script type="text/javascript">
	// Get this script ready when the page loads
	$(document).ready(function() {
		$(".scrollDown").click(function(event) {
			// Select the body of the page and scroll down by 650 pixels worth
			$("html, body").animate({ scrollTop: "+=900px" }, 800);
		});
