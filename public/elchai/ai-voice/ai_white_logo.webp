       <script>
document.addEventListener('DOMContentLoaded', function () {
    const DESKTOP = window.matchMedia('(min-width: 992px)').matches;

    /* ===========================MAIN MEGA MENU OPEN/CLOSE  ============================ */
    document.querySelectorAll('.mega-dropdown').forEach(dropdown => {

        const toggle = dropdown.querySelector('.mega-toggle');
        const menu   = dropdown.querySelector('.mega-menu, .mega-menu_short');
        if (!toggle || !menu) return;

        // Desktop → hover
        if (DESKTOP) {
            dropdown.addEventListener('mouseenter', () => {
                menu.classList.add('show');
            });
            dropdown.addEventListener('mouseleave', () => {
                menu.classList.remove('show');
            });
        }

        // Mobile → click
        toggle.addEventListener('click', e => {
            e.preventDefault();
            document.querySelectorAll('.mega-menu.show, .mega-menu_short.show')
                .forEach(m => m !== menu && m.classList.remove('show'));

            menu.classList.toggle('show');
        });
    });

    /* ===========================LEFT → RIGHT SUBMENU SWITCH============================ */
    document.querySelectorAll('.mega-menu').forEach(megaMenu => {

        // ✅ ONLY CHANGE HERE
        const leftItems = megaMenu.querySelectorAll('.left-menu-list li:not(.nomenu)');
        const panels    = megaMenu.querySelectorAll('.submenu-content');
        const rightWrap = megaMenu.querySelector('.menu-right');

        leftItems.forEach(item => {
            const activate = () => {
                leftItems.forEach(li => li.classList.remove('active'));
                panels.forEach(p => p.classList.remove('active'));

                item.classList.add('active');

                const target = item.dataset.target;
                const panel  = megaMenu.querySelector('#' + target);
                if (!panel) return;

                panel.classList.add('active');

                if (!DESKTOP) {
                    item.after(panel);
                } else {
                    rightWrap.appendChild(panel);
                }
            };

            // Desktop hover
            item.addEventListener('mouseenter', () => DESKTOP && activate());

            // Mobile click
            item.addEventListener('click', e => {
                e.preventDefault();
                activate();
            });
        });
    });

    /* ===========================CLICK OUTSIDE → CLOSE  ============================ */
    document.addEventListener('click', e => {
        if (!e.target.closest('.mega-dropdown')) {
            document.querySelectorAll('.mega-menu.show, .mega-menu_short.show')
                .forEach(m => m.classList.remove('show'));
        }
    });
});
</script>


