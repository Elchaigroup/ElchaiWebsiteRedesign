	$('.slider-banner-js').slick({
		slidesToShow: 4,
		slidesToScroll: 1,
		dots: false,
		arrow: false,
		autoplay: true,
		autoplaySpeed: 2000,
		focusOnSelect: true,
		rtl: true,
		asNavFor: '.slider-title-js',
		nextArrow: '<button class="slick-next"> <img src="https://www.elchaigroup.com/wp-content/themes/prisma-child/media/2024/10/royo/next-arrow.png" alt=""></button>',
		responsive: [
			{
				breakpoint: 1140,
				settings: {
					slidesToShow: 3,
					dots: false,
					arrows: false,
				}
			},
			{
				breakpoint: 991,
				settings: {
					slidesToShow: 3,
					dots: false,
					arrows: false,
					centerMode: true
				}
			},
			{
				breakpoint: 767,
				settings: {
					slidesToShow: 1,
					dots: false,
					arrows: false,
					centerMode: true
				}
			},
			{
				breakpoint: 576,
				settings: {
					slidesToShow: 1,
					dots: false,
					arrows: false,
					centerMode: true
				}
			},
		]
	});
	$('.slider-title-js').slick({
		slidesToShow: 1,
		slidesToScroll: 1,
		arrows: false,
		fade: true,
		asNavFor: '.slider-banner-js',
	});
	// On before slide change
	if($(window).width() >= 991){
		$('.slider-banner-js').on('afterChange', function(event, slick, currentSlide, nextSlide){
			$('.slick-slide').removeClass('slick-active-first slick-active-first');
			$('.slick-active').eq(0).addClass('slick-active-first');
		}).trigger('afterChange');
	}
	var $slider = $('.slider-banner-js');
	if ($slider.length) {
		var currentSlide;
		var slidesCount;
		var sliderCounter = document.createElement('div');
		sliderCounter.classList.add('slider__counter');

		var updateSliderCounter = function(slick, currentIndex) {
			currentSlide = slick.slickCurrentSlide() + 1;
			//slidesCount = slick.slideCount;
			slidesCount = $(".slider-banner-js").slick("getSlick").slideCount;
			$(sliderCounter).text(currentSlide + '/' +slidesCount)
		};

		$slider.on('init', function(event, slick) {
			$slider.append(sliderCounter);
			updateSliderCounter(slick);
		});

		$slider.on('afterChange', function(event, slick, currentSlide) {
			updateSliderCounter(slick, currentSlide);
		});
		$slider.slick();
	}
</script>
