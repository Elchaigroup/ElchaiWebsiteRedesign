    <script>
        // Destroy Slick properly when modal hides — removes all cloned slides from DOM
        $('#galleryModal').on('hide.bs.modal', function () {
            if ($('.slider-event-for-js').hasClass('slick-initialized')) {
                $('.slider-event-nav-js').slick('destroy');
                $('.slider-event-for-js').slick('destroy');
            }
        });

        $('#galleryModal').on('shown.bs.modal', function () {
            // Only initialise if not already running (guard against double-fire)
            if ($('.slider-event-for-js').hasClass('slick-initialized')) {
                return;
            }

            $('.slider-event-for-js').slick({
                slidesToShow: 1,
                slidesToScroll: 1,
                arrows: false,
                fade: true,
                autoplay: true,
                autoplaySpeed: 2000,
                speed: 300,
                asNavFor: '.slider-event-nav-js'
            });

            $('.slider-event-nav-js').slick({
                slidesToShow: 5,
                slidesToScroll: 1,
                asNavFor: '.slider-event-for-js',
                centerMode: true,
                focusOnSelect: true,
                prevArrow: '<div class="slick-prev"><img class="img-fluid" src="https://www.elchaigroup.com/wp-content/themes/prisma-child/media/2025/images/slider-arrow-left.webp?var=303154805" alt="Arrow"></div>',
                nextArrow: '<div class="slick-next"><img class="img-fluid" src="https://www.elchaigroup.com/wp-content/themes/prisma-child/media/2025/images/slider-arrow-right.webp?var=1906586527" alt="Arrow"></div>',
                responsive: [
                    {
                        breakpoint: 991,
                        settings: {
                            centerPadding: '0px',
                            slidesToShow: 5
                        }
                    },
                    {
                        breakpoint: 768,
                        settings: {
                            centerPadding: '40px',
                            slidesToShow: 3
                        }
                    },
                    {
                        breakpoint: 480,
                        settings: {
                            centerPadding: '20px',
                            slidesToShow: 3
                        }
                    }
                ]
            });

            $('.slider-event-for-js, .slider-event-nav-js').slick('setPosition');
        });
    </script>

    <script>
        $('.slider-resources-js').slick({
            arrows: false,
            autoplay: true,
            dots: false,
            centerMode: true,
            centerPadding: '0px',
            slidesToShow: 3,
            responsive: [
                {
                    breakpoint: 991,
                    settings: {
                        arrows: false,
                        centerMode: true,
                        centerPadding: '0px',
                        slidesToShow: 3
                    }
                },
                {
                    breakpoint: 768,
                    settings: {
                        arrows: false,
                        centerMode: true,
                        centerPadding: '40px',
                        slidesToShow: 3
                    }
                },
                {
                    breakpoint: 480,
                    settings: {
                        centerMode: true,
                        centerPadding: '40px',
                        slidesToShow: 1
                    }
                }
            ]
        });
    </script>
    <script>
		document.addEventListener("DOMContentLoaded", function () {
			const indicators = document.querySelectorAll(".casestudies-nav");
			const carousel = document.querySelector("#carousel-caseStudy");

			// Sync Indicators with Slides
			carousel.addEventListener("slide.bs.carousel", function (event) {
				indicators.forEach((indicator) => indicator.classList.remove("active"));
				indicators[event.to].classList.add("active");

				// Scroll active indicator to center
				scrollIndicatorToCenter(indicators[event.to]);
			});

			// Horizontal Scroll for Indicators
			indicators.forEach((indicator) => {
				indicator.addEventListener("click", function () {
					scrollIndicatorToCenter(indicator);
				});
			});

			// Function to scroll active indicator to center
			function scrollIndicatorToCenter(activeIndicator) {
				const container = document.querySelector(".horizontalDots");
				const containerWidth = container.offsetWidth;
				const indicatorLeft = activeIndicator.offsetLeft;
				const indicatorWidth = activeIndicator.offsetWidth;

				// Calculate the center position
				const scrollPosition = indicatorLeft - containerWidth / 2 + indicatorWidth / 2;

				// Smooth scroll to the calculated position
				container.scrollTo({
					left: scrollPosition,
					behavior: "smooth",
				});
			}
		});
	</script>
	
	<script>
document.addEventListener('DOMContentLoaded', function () {

    const sections = document.querySelectorAll('section');
    const navItems = document.querySelectorAll('#solution-list_mob .solution-list__item');
    const navList = document.getElementById('solution-list_mob');

 
    function onScroll() {
        let currentSection = null;

        sections.forEach(section => {
            const rect = section.getBoundingClientRect();
            if (rect.top <= window.innerHeight / 2 && rect.bottom > window.innerHeight / 2) {
                currentSection = section;
            }
        });

        if (currentSection) {
            navItems.forEach(item => {
                item.classList.remove('active');
                if (item.dataset.section === currentSection.id) {
                    item.classList.add('active');
                    centerNavItem(item);
                }
            });
        }
    }

    function centerNavItem(item) {
        const navRect = navList.getBoundingClientRect();
        const itemRect = item.getBoundingClientRect();
        const offset = itemRect.left - navRect.left + itemRect.width / 2 - navRect.width / 2;
        navList.style.transform = `translateX(${-offset}px)`;
    }

function scrollToSection(sectionId) {
    const section = document.getElementById(sectionId);
    if (!section) return;

    section.scrollIntoView({
        behavior: 'smooth',
        block: 'start'
    });
}


    navItems.forEach(item => {
        item.addEventListener('click', function (e) {
            e.preventDefault(); // 🔴 stop anchor default jump
            scrollToSection(this.dataset.section);
        });
    });

    window.addEventListener('scroll', onScroll);
    onScroll();
});
</script>


