	.section--contact .title-tag {color: #888888;font-size: 18px;line-height: 3rem;text-transform: uppercase;padding-left: 30px;position: relative;margin-bottom: calc(0.5rem + 0.5vw);font-weight: 600;letter-spacing: 1px;}
	.section--contact .title-tag:before {content: "";position: absolute;height: 16px;width: 16px;top: 50%;transform: translateY(-50%);left: 0;background-image:url(https://www.elchaigroup.com/wp-content/themes/prisma-child/media/2025/images/tag-star.svg);}
