    ul.list-items {
    margin-top: 2rem;
}
    .section--partnership .title-tag:before {
    filter: brightness(0) invert(1);
}
    .partners-slider .slick-slide img {
    display: block;
    margin: 0 30px;
        width: 180px;
}
   
    .section--partnership, .section--Rockefeller {
    background: #000;
    color: #fff;
}
    ul.Rockefeller_list li {
    font-size: 20px;
    font-weight: 600;
    padding: 10px 0;
}
    ul.Rockefeller_list {
    margin-top: calc(1rem + 1vw);
}
    
    
    @keyframes partner-tuple-scroll {
    0% {
        transform: translateX(-100%)
    }

    to {
        transform: translateX(0%)
    }
}
    .trading_content {
    display: flex;
    overflow: clip;
    position: relative;
    -webkit-user-select: none;
    user-select: none;
}
    .trading_content p {
    animation: partner-tuple-scroll 200s linear infinite;
    display: grid;
    flex-shrink: 0;
    gap: 6px;
    grid-auto-flow: column;
    justify-content: space-around;
    min-width: 100%;
    font-size: calc(2rem + 1vw);
    margin: 20px 0;
    color: #3f3f3f; 
}

    
    
    @media(min-width:768px){
        
        
        .Partnership-btn button {
            margin-left: auto;
        }
        .time-btn button {
