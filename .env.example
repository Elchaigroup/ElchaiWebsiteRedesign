# ─────────── Lead capture ───────────
# Optional: webhook the /api/lead route POSTs to in addition to WordPress.
# Slack incoming-webhook, Zapier catch hook, Airtable webhook, etc.
LEAD_WEBHOOK_URL=

# ─────────── Lead → Email (Resend) ───────────
# Sign up at https://resend.com, create an API key under
# https://resend.com/api-keys, paste it here.
RESEND_API_KEY=
# Recipient (default if blank: info@elchaigroup.com)
LEAD_EMAIL_TO=info@elchaigroup.com
# Sender. Must be on a Resend-verified domain. For testing before you
# verify elchaigroup.com you can use "onboarding@resend.dev" — Resend
# will only deliver such test sends to the account-owner address.
LEAD_EMAIL_FROM=Elchai Website <leads@elchaigroup.com>

# ─────────── WordPress integration ───────────
# Base URL of the WP install. No trailing slash. Leave blank to disable
# the WP integration entirely — the site falls back to static content.
WP_BASE_URL=

# WordPress Application Password (wp-admin → Users → Profile → Application
# Passwords). Used for authenticated reads and for the lead POST.
WP_APP_USER=
WP_APP_PASSWORD=

# Optional: override the lead endpoint. Defaults to
# ${WP_BASE_URL}/wp-json/elchai/v1/leads (see docs/wordpress.md).
WP_LEAD_ENDPOINT=

# ─────────── Revalidation webhook ───────────
# Shared secret. WordPress hits /api/revalidate with this in the
# x-revalidate-secret header after publishing/updating a post.
REVALIDATE_SECRET=
